{
  "name": "codeguard-mcp",
  "version": "0.2.0",
  "description": "AI code review MCP server — automated pattern detection for bugs, security issues, and silent failures",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codeguard": "./dist/mcp/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "dev": "tsc --watch",
    "mcp": "node dist/mcp/server.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "code-review",
    "static-analysis",
    "ai",
    "claude",
    "linting",
    "security"
  ],
  "author": "Idris Idriszade",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrzadexinho/codeguard.git"
  },
  "bugs": {
    "url": "https://github.com/mrzadexinho/codeguard/issues"
  },
  "homepage": "https://github.com/mrzadexinho/codeguard#readme"
}
